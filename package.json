{
  "name": "meterkit-lite",
  "version": "1.0.0",
  "description": "Free MIT token metering & cost tracking for Next.js AI apps — the open funnel for MeterKit Pro.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./ui/theme.css": "./src/ui/theme.css",
    "./ui/lite-dashboard.css": "./src/ui/lite-dashboard.css"
  },
  "sideEffects": false,
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "tokens",
    "metering",
    "openai",
    "nextjs",
    "cost",
    "llm"
  ],
  "homepage": "https://meterkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meterkit/meterkit-lite.git"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
